# Server port (Railway sets this automatically — leave blank in production)
PORT=5000

# Neon Postgres connection string
# Get this from your Neon project dashboard -> Connection Details
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Your deployed Vercel frontend URL, used to allow CORS requests
# e.g. https://priceguard.vercel.app
FRONTEND_URL=

# Get this by creating a bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Cron schedule for automatic price checks (default: every 6 hours)
# Format: minute hour day month weekday
CRON_SCHEDULE=0 */6 * * *
